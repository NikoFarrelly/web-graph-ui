    "lint": "eslint .",
    "clean": "rm -rf dist",
    "preview": "vite preview",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typescript": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
